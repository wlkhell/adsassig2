#include <iostream>

using namespace std;

void moveZeroes(int nums[], int size) {
    int insertPos = 0;
    for (int i = 0; i < size; i++) {
        if (nums[i] != 0) {
            int temp = nums[i];
            nums[i] = nums[insertPos];
            nums[insertPos] = temp;
            insertPos++;
        }
    }
}
